# Add global exception handler
app.add_exception_handler(Exception, global_exception_handler)

# Auto-instrument FastAPI for tracing (if enabled)
instrument_fastapi(app)

# Add middlewares (order matters: first added = outermost layer)
# Middleware execution stack (outermost to innermost):
# 1. CORS - handles cross-origin requests (outermost, executes first)
# 2. Security - adds security headers
# 3. FeatureFlags - kill switches and maintenance mode
# 4. RequestSizeLimit - rejects oversized payloads early
# 5. Tracing - generates correlation_id + trace spans
# 6. Timeout - enforces request timeout (after tracing for correlation_id)
# 7. Logging - logs requests/responses with correlation_id
# 8. Organization - extracts user_id, org_id, plan from token/context
# 9. RBAC - checks permissions using user_id + org_id
# 10. RateLimit - limits requests per user/plan (innermost, executes last)

# CORS configuration (added first = outermost = executes first)
# Conforme python.state.rules.md BLOC-002: Settings via pydantic-settings
# Uses centralized settings for environment-aware CORS configuration
cors_origins = settings.get_cors_origins_list()
app.add_middleware(
    CORSMiddleware,
    allow_origins=cors_origins,
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# Security headers
app.add_middleware(SecurityHeadersMiddleware)

# Feature flags and kill switches (early exit for disabled features)
app.add_middleware(FeatureFlagsMiddleware)

# Request size limit (reject oversized payloads before logging/processing)
app.add_middleware(RequestSizeLimitMiddleware)

# Tracing middleware (provides correlation IDs + OpenTelemetry tracing)
# Sets correlation_id in request.state for all subsequent middlewares
app.add_middleware(TracingMiddleware)

# Request timeout enforcement (prevents zombie requests)
app.add_middleware(TimeoutMiddleware)

# Request logging (captures all subsequent middleware/route errors)
app.add_middleware(RequestLoggingMiddleware)

# Organization context middleware
# Extracts user_id, org_id, org_role, plan from JWT token
# Sets these in request.state for use by RBAC and RateLimit
app.add_middleware(OrganizationContextMiddleware)

# RBAC middleware (checks feature access using user_id + org context)
# Requires user_id to be set by OrganizationContextMiddleware
app.add_middleware(RBACMiddleware)

# Rate limiting middleware (per-user and plan-based limits)
# Uses plan information set by OrganizationContextMiddleware
app.add_middleware(RateLimitMiddleware)

# Initialize and mount routers
# Auth router (public endpoints)
auth_router = AuthRouter()
auth_router.initialize_services()
app.include_router(auth_router.get_router(), prefix="/api/v1")

# Me router (authenticated endpoints)
me_router = MeRouter()
me_router.initialize_services()
