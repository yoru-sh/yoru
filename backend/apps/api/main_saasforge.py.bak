app.include_router(admin_webhooks_router.get_router(), prefix="/api/v1")

# Admin organizations router (system-wide organization management)
admin_organizations_router = AdminOrganizationsRouter()
admin_organizations_router.initialize_services()
app.include_router(admin_organizations_router.get_router(), prefix="/api/v1")

# Heartbeat router (session keep-alive)
heartbeat_router = HeartbeatRouter()
heartbeat_router.initialize_services()
app.include_router(heartbeat_router.get_router(), prefix="/api/v1")

# Organizations router (my organizations - multi-tenancy)
# Mounted at /api/v1/me/organizations
organizations_router = OrganizationsRouter()
