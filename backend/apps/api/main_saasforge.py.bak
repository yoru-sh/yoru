app.include_router(org_invitations_router.get_router(), prefix="/api/v1")


@app.get("/", tags=["root"])
async def root():
    """Root endpoint redirecting to API docs."""
    return {
        "message": "Welcome to SaaS API",
        "docs": "/api/docs",
        "health": "/api/ping",
    }


@app.get("/health", tags=["health"])
async def health(request: Request):
    """
    Health check endpoint for container orchestration.

    Returns:
        - 200: Service is healthy and ready to accept requests
        - 503: Service is shutting down (draining connections)
    """
    # Check if shutdown is in progress
    shutdown_manager = getattr(request.app.state, "shutdown_manager", None)

    if shutdown_manager and shutdown_manager.is_shutting_down():
        from fastapi.responses import JSONResponse
        return JSONResponse(
            status_code=503,
            content={"status": "shutting_down", "message": "Service is draining connections"}
        )

    return {"status": "healthy"}
