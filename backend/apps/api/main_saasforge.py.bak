# Lifespan context manager for startup and shutdown
@asynccontextmanager
async def lifespan(app: FastAPI):
    """
    Lifespan context manager for startup and shutdown events.

    Startup:
    - Initialize tracing (OpenTelemetry)
    - Setup shutdown manager
    - Register cleanup functions

    Shutdown:
    - Execute graceful shutdown
    - Clean up connections
    """
    # Startup
    logger.log_info("Application startup - initializing services")

    # Initialize tracing
    tracer = init_tracer(service_name="saas-api")
    if tracer:
        # Auto-instrument libraries
        instrument_httpx()
        instrument_redis()
        logger.log_info("Distributed tracing initialized")

    # Initialize shutdown manager
    shutdown_manager = ShutdownManager(timeout=30)
    app.state.shutdown_manager = shutdown_manager

    # Register cleanup functions
    # Redis cleanup
    try:
        redis_manager = RedisManager()
        shutdown_manager.register_cleanup(redis_manager.close)
        logger.log_debug("Registered Redis cleanup")
    except Exception as e:
        logger.log_warning(f"Failed to register Redis cleanup: {e}")

    # Setup signal handlers for graceful shutdown
    def setup_signal_handlers():
        """Setup signal handlers for SIGTERM and SIGINT."""
        loop = asyncio.get_event_loop()

        def handle_signal(sig):
            logger.log_info(f"Received signal {sig}, initiating shutdown")
            loop.create_task(shutdown_manager.shutdown())
            # Give some time for graceful shutdown before forcing exit
            loop.call_later(shutdown_manager.timeout + 5, loop.stop)

        for sig in (signal.SIGTERM, signal.SIGINT):
            signal.signal(sig, lambda s, f: handle_signal(s))

        logger.log_info("Signal handlers registered for graceful shutdown")

    setup_signal_handlers()

    logger.log_info("Application startup complete")

    yield

    # Shutdown
    logger.log_info("Application shutdown - running cleanup")
    await shutdown_manager.shutdown()
    logger.log_info("Application shutdown complete")


# Create FastAPI app with enhanced OpenAPI documentation
app = FastAPI(
    lifespan=lifespan,
    title="SaaS API",
    version="1.0.0",
    description="""
## Production-Ready SaaS Backend API

Complete FastAPI backend with authentication, subscriptions, notifications, and RBAC.

### Features

* **Authentication**: JWT-based auth with Supabase (signup, signin, refresh, signout)
* **User Management**: Profile management with role-based access control
* **Subscriptions**: Flexible plan-based subscriptions with features and grants
* **Notifications**: In-app notification system with real-time updates
* **Invitations**: User invitation system with email tokens
* **Promo Codes**: Discount codes with usage limits and validation
* **Admin Tools**: Admin-only endpoints for management and broadcasting

### Authentication

All protected endpoints require a Bearer token in the Authorization header:

```
Authorization: Bearer <your_access_token>
```

Get your token by calling `/api/v1/auth/signin` or `/api/v1/auth/signup`.

### Rate Limiting

API calls are subject to rate limiting based on your subscription plan.

### Support

- **Swagger UI**: `/api/docs` (interactive documentation)
- **ReDoc**: `/api/redoc` (alternative documentation)
- **OpenAPI Schema**: `/api/openapi.json`
    """,
    docs_url="/api/docs",
    redoc_url="/api/redoc",
    openapi_url="/api/openapi.json",
    contact={
        "name": "API Support",
        "email": "support@example.com",
    },
