app.include_router(subscriptions_router.get_router(), prefix="/api/v1")

# Features router (public and admin endpoints)
features_router = FeaturesRouter()
features_router.initialize_services()
app.include_router(features_router.get_router(), prefix="/api/v1")

# Promo router (promo code validation and management)
promo_router = PromoRouter()
promo_router.initialize_services()
app.include_router(promo_router.get_router(), prefix="/api/v1")

# Grants router (admin grant management)
grants_router = GrantsRouter()
grants_router.initialize_services()
app.include_router(grants_router.get_router(), prefix="/api/v1")

# Invitations router (user invitation management)
invitations_router = InvitationsRouter()
