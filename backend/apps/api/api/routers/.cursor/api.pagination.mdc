**Template pagination standard** :

```python
from fastapi import Query
from pydantic import BaseModel, Field

class PaginationMetadata(BaseModel):
    total: int = Field(..., description="Total items")
    page: int = Field(..., ge=1, description="Current page")
    page_size: int = Field(..., description="Items per page")
    total_pages: int = Field(..., description="Total pages")
    has_more: bool = Field(..., description="Has next page")

class EntityListResponse(BaseModel):
    items: list[EntityResponse]
    pagination: PaginationMetadata

@router.get("", response_model=EntityListResponse)
async def list_entities(
    page: int = Query(1, ge=1, description="Page number"),
    page_size: int = Query(50, ge=1, le=200, description="Items per page"),
    sort_by: str = Query("created_at", description="Sort field"),
    sort_order: str = Query("desc", description="Sort order: asc, desc"),
    status: str | None = Query(None, description="Filter by status")
):
    offset = (page - 1) * page_size
    
    items = await service.list(
        offset=offset,
        limit=page_size,
        sort_by=sort_by,
        sort_order=sort_order,
        filters={"status": status} if status else {}
    )
    
    total = await service.count(filters={"status": status} if status else {})
    total_pages = (total + page_size - 1) // page_size
    
    return EntityListResponse(
        items=items,
        pagination=PaginationMetadata(
            total=total,
            page=page,
            page_size=page_size,
            total_pages=total_pages,
            has_more=page < total_pages
        )
    )
```

**Commandes utiles** :

```bash
# Vérifier endpoints sans pagination
grep -r "@router.get.*list" app/ -A 10 | grep -v "page:"

# Vérifier limites manquantes
grep -r "page_size.*Query" app/ | grep -v "le="
```
