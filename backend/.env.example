# SaaS API Configuration

# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================
# SaaSForge supports separate development and production environments.
#
# Development Environment:
#   - See: docker/config/env/.env.development
#   - Single API instance, direct port access (no nginx)
#   - Debug logging (LOG_LEVEL=DEBUG)
#   - Log masking disabled (DISABLE_LOG_MASKING=true)
#   - Relaxed rate limiting
#   - .env files for secrets
#
# Production Environment:
#   - See: docker/config/env/.env.production
#   - 3 API replicas with nginx load balancer
#   - Production logging (LOG_LEVEL=INFO)
#   - Log masking enabled (DISABLE_LOG_MASKING=false - REQUIRED by BLOC-008)
#   - Strict rate limiting
#   - Encrypted secrets (git-crypt) or platform secret injection
#   - SSL/TLS required
#
# Copy the appropriate environment file to .env and customize:
#   cp docker/config/env/.env.development .env   # For local development
#   cp docker/config/env/.env.production .env    # For production deployment
# =============================================================================

# =============================================================================
# CORE SETTINGS
# =============================================================================
APP_ENV=development                  # "development" or "production"
ENVIRONMENT=development              # Legacy compatibility
APP_VERSION=1.0.0

# Logging
LOG_LEVEL=INFO                       # DEBUG (dev) or INFO/WARNING/ERROR (prod)
DISABLE_LOG_MASKING=false            # true (dev only), false (REQUIRED in prod)
LOG_RETENTION_DAYS=7                 # 7 (dev), 30+ (prod)

# Security
ENABLE_RATE_LIMITING=true            # false (dev), true (prod)
REQUEST_TIMEOUT_SECONDS=30           # 300 (dev), 30 (prod)
MAX_REQUEST_SIZE_MB=10               # 50 (dev), 10 (prod)

# Domains
API_DOMAIN=api.dev.example.local     # api.dev.example.local (dev), api.prod.yourdomain.com (prod)
WORKER_DOMAIN=worker.dev.example.local
API_URL=http://localhost:8002        # http://localhost:8002 (dev), https://api.prod.yourdomain.com (prod)

# Secrets management
# Development: .env files
# Production: Encrypted .env files (git-crypt) or platform secrets (Docker/K8s/PaaS)

# =============================================================================
# SUPABASE DATABASE
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# Required: backend defaults to service-role (bypasses RLS). See issue #48.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# REDIS
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# CIRCUIT BREAKERS (Resilience)
# =============================================================================
# Enable/disable circuit breaker protection
ENABLE_CIRCUIT_BREAKERS=true

# Supabase circuit breaker configuration
SUPABASE_CIRCUIT_FAILURE_THRESHOLD=5
SUPABASE_CIRCUIT_TIMEOUT=60

# Redis circuit breaker configuration
REDIS_CIRCUIT_FAILURE_THRESHOLD=5
REDIS_CIRCUIT_TIMEOUT=30

# Webhook circuit breaker configuration
WEBHOOK_CIRCUIT_FAILURE_THRESHOLD=5
WEBHOOK_CIRCUIT_TIMEOUT=60

# =============================================================================
# RATE LIMITING
# =============================================================================
# Enable/disable rate limiting
ENABLE_RATE_LIMITING=true

# Rate limit window (seconds)
RATE_LIMIT_WINDOW_SECONDS=60

# Rate limits per plan (requests per window)
RATE_LIMIT_FREE_PLAN=100
RATE_LIMIT_PRO_PLAN=1000
RATE_LIMIT_ENTERPRISE_PLAN=10000
RATE_LIMIT_UNAUTHENTICATED=20

# =============================================================================
# DISTRIBUTED TRACING (OpenTelemetry)
# =============================================================================
# Enable/disable distributed tracing
ENABLE_TRACING=false

# Exporter type: "jaeger" or "otlp"
OTEL_EXPORTER_TYPE=jaeger

# Service name for tracing
OTEL_SERVICE_NAME=saas-api

# Sampling rate (0.0 to 1.0, where 1.0 = 100% of requests)
OTEL_SAMPLING_RATE=1.0

# Jaeger configuration (when OTEL_EXPORTER_TYPE=jaeger)
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# OTLP configuration (when OTEL_EXPORTER_TYPE=otlp)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# =============================================================================
# GRACEFUL SHUTDOWN
# =============================================================================
# Maximum seconds to wait for graceful shutdown
SHUTDOWN_TIMEOUT=30

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# EMAIL SERVICE
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Your SaaS

# =============================================================================
# WEBHOOKS
# =============================================================================
WEBHOOK_TIMEOUT=30
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY=5

# =============================================================================
# NOTIFICATIONS
# =============================================================================
NOTIFICATION_DEFAULT_EXPIRY_DAYS=30

# =============================================================================
# SUBSCRIPTIONS
# =============================================================================
# Default trial period in days
DEFAULT_TRIAL_PERIOD_DAYS=14

# =============================================================================
# AUTH — password reset (wave-14 C4)
# =============================================================================
# Feature-flag for POST /api/v1/auth/password-reset-request and
# POST /api/v1/auth/password-reset-confirm. When unset/false (default) both
# routes 404 so the surface is indistinguishable from an unknown path (no
# information leak about the feature's existence). Flip to true only after
# the follow-up wave lands password storage on the user model and wires real
# email delivery. See vault/audits/auth-password-reset-design.md.
AUTH_PASSWORD_RESET_ENABLED=false

# =============================================================================
# BILLING — Polar checkout (US-15, wave-20-B C1)
# =============================================================================
# Polar.sh API key. Empty/unset → the module-level `_polar_client` in
# apps/api/api/routers/billing/checkout.py stays a MagicMock (no network).
# Set this (+ a real key) only in prod or when running integration smoke
# against Polar test mode. NEVER commit a populated value.
POLAR_API_KEY=
# Polar price/plan IDs for the two sellable tiers. Defaults (`plan_team_mock`,
# `plan_org_mock`) are only used by the MagicMock path — real environments
# must replace them with Polar dashboard IDs (see vault/BILLING-PLANS-V1.md §3).
POLAR_TEAM_PLAN_ID=
POLAR_ORG_PLAN_ID=

# =============================================================================
# BILLING — Polar webhook (US-16, wave-20-C C1)
# =============================================================================
# HMAC-SHA256 shared secret for the Polar webhook. Header on inbound:
# `X-Polar-Signature`, value = hex(hmac-sha256(secret, raw-body)). When unset
# the webhook returns 503 "Webhook secret not configured" — it never silently
# accepts. Copy the secret from the Polar dashboard webhook-endpoint page.
POLAR_WEBHOOK_SECRET=

# ---------- Email delivery (Resend) ----------
# Used by backend-side transactional mail (password reset, welcome, account deletion).
# Supabase Auth SMTP is wired separately at the Supabase dashboard level; see vault/SMTP-SETUP.md.
# Get the API key from https://resend.com → API Keys (prefix: re_...).
RESEND_API_KEY=re_your_key_here
# Sender address used by backend-side mailers. Must match a Resend-verified domain.
SMTP_FROM=auth@opentruth.ch
