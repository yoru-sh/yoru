# ============================================
# Email Service Configuration
# ============================================

# Provider Selection
# Options: smtp, sendgrid, resend
EMAIL_PROVIDER=smtp

# ============================================
# SMTP Configuration (Gmail, Outlook, etc.)
# ============================================

# SMTP Server
SMTP_HOST=smtp.gmail.com              # Gmail: smtp.gmail.com
                                      # Outlook: smtp.office365.com
                                      # Custom: your-smtp-server.com

SMTP_PORT=587                         # TLS: 587, SSL: 465

# Authentication
SMTP_USERNAME=your-app@gmail.com      # Your email or SMTP username
SMTP_PASSWORD=your-app-password       # For Gmail: Use App Password (not your regular password)
                                      # Create at: https://myaccount.google.com/apppasswords
                                      # Requires 2FA enabled

SMTP_USE_TLS=true                     # Use TLS encryption (recommended)

# Sender Identity
SMTP_FROM_EMAIL=noreply@yourapp.com   # Email address shown as sender
SMTP_FROM_NAME=YourApp                # Display name shown as sender

# ============================================
# SendGrid Configuration (Recommended for Production)
# ============================================

# Uncomment when using SendGrid
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.xxx...               # Get from https://sendgrid.com
# SENDGRID_FROM_EMAIL=noreply@yourapp.com  # Must be verified domain
# SENDGRID_FROM_NAME=YourApp

# Setup: https://sendgrid.com
# 1. Sign up and verify your domain
# 2. Create API Key with "Mail Send" permission
# 3. Free tier: 100 emails/day

# ============================================
# Resend Configuration (Modern Alternative)
# ============================================

# Uncomment when using Resend
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxx...                 # Get from https://resend.com
# RESEND_FROM_EMAIL=noreply@yourapp.com    # Must be verified domain

# Setup: https://resend.com
# 1. Sign up and verify your domain
# 2. Create API Key
# 3. Free tier: 3,000 emails/month
# 4. Best developer experience, modern API

# ============================================
# Template Context (Global Variables)
# ============================================

# Brand Information
EMAIL_BRAND_NAME=SaaSForge            # Company/Product name shown in emails
EMAIL_SUPPORT_EMAIL=support@saasforge.com  # Support contact email
EMAIL_COMPANY_ADDRESS=123 Main St, City, State, Country  # Footer address

# ============================================
# Application URLs
# ============================================

# Frontend URL (used for email links)
APP_URL=http://localhost:3000         # Development: http://localhost:3000
                                      # Production: https://yourapp.com

# ============================================
# Email Behavior
# ============================================

# Retry Configuration
EMAIL_RETRY_ATTEMPTS=3                # Number of retry attempts on failure
EMAIL_TIMEOUT=30                      # Timeout in seconds for email operations

# ============================================
# Gmail Setup Instructions
# ============================================
#
# 1. Enable 2-Factor Authentication:
#    - Go to https://myaccount.google.com/security
#    - Enable 2-Step Verification
#
# 2. Create App Password:
#    - Go to https://myaccount.google.com/apppasswords
#    - Select "Mail" and your device
#    - Copy the 16-character password
#
# 3. Use in Configuration:
#    SMTP_HOST=smtp.gmail.com
#    SMTP_PORT=587
#    SMTP_USERNAME=your-email@gmail.com
#    SMTP_PASSWORD=your-16-char-app-password
#    SMTP_USE_TLS=true
#
# ============================================
