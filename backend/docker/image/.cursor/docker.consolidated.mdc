## 🔍 Commandes de Détection

```bash
#!/bin/bash
# validate_docker.sh

echo "🔍 Validation règles Docker..."

# Dockerfile
echo "❌ Images non-slim:"
grep "FROM python" **/Dockerfile | grep -v "slim"

echo "❌ Containers root:"
find . -name "Dockerfile" -exec sh -c 'grep -L "^USER" "$1"' _ {} \;

echo "❌ Pas de multi-stage:"
find . -name "Dockerfile" -exec sh -c 'test $(grep -c "^FROM" "$1") -eq 1 && echo "$1"' _ {} \;

echo "❌ Pas de HEALTHCHECK:"
find . -name "Dockerfile" -exec sh -c 'grep -L "HEALTHCHECK" "$1"' _ {} \;

echo "❌ Pas de .dockerignore:"
find . -name "Dockerfile" -exec sh -c 'test ! -f "$(dirname "$1")/.dockerignore" && echo "$1"' _ {} \;

# Compose
echo "❌ Pas de réseau custom:"
grep -L "networks:" docker-compose*.yml

echo "❌ Ports DB exposés:"
grep "5432:5432\|6379:6379\|27017:27017" docker-compose*.yml

echo "❌ Secrets inline:"
grep -E "PASSWORD=|API_KEY=|SECRET=" docker-compose*.yml | grep -v "env_file"

echo "❌ Pas de restart:"
grep -L "restart:" docker-compose*.yml

echo "❌ Pas de logging rotation:"
grep -L "max-size:" docker-compose*.yml

echo "❌ IP hardcodées:"
grep -E "[0-9]{1,3}(\.[0-9]{1,3}){3}" docker-compose*.yml

echo "✅ Validation terminée"
