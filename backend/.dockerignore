# Receipt backend image build context (vault/DEPLOY-V0.md §1(a))
# Keep the build context minimal: the smaller it is, the faster
# `docker build` ships it to the daemon and the smaller the final image.

# Runtime data — must never be baked into the image
data/
logs/
*.db
*.db-journal
*.db-wal
*.db-shm

# Backups left around by previous strips/refactors (e.g. main_saasforge.py.bak)
*.bak
*.orig

# Python build artefacts and caches
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/
build/
dist/

# Tests don't run in the prod image
tests/
**/tests/

# Local dev environments (uv creates .venv at the repo root during dev)
.venv/
venv/
env/

# Secrets and per-env configuration — image must read env at runtime
.env
.env.*
!.env.example

# Documentation isn't shipped in the runtime image
*.md

# Editor / IDE / OS noise
.idea/
.vscode/
.DS_Store
.git/
.gitignore
.github/

# Docker artefacts that don't need to ship into the image
docker-compose*.yml
Dockerfile
.dockerignore

# Keep these even though *.md is excluded above — uv needs README.md to load
# pyproject.toml (readme = "README.md") at build time.
!README.md
